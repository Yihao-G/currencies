<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
                android:id="@+id/widget_root"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/widget_background"
                android:padding="8dp">

    <!-- Flag Row -->
    <LinearLayout
            android:id="@+id/layout_flags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

        <ImageView
                android:id="@+id/image_flag_from"
                android:layout_width="24dp"
                android:layout_height="17dp"
                android:scaleType="fitXY"
                android:contentDescription="@null"/>

        <ImageView
                android:id="@+id/image_chevron"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginHorizontal="4dp"
                android:src="@drawable/ic_chevron_right"
                android:alpha="0.5"
                android:contentDescription="@null"
                android:tint="?android:attr/textColorSecondary"/>

        <ImageView
                android:id="@+id/image_flag_to"
                android:layout_width="24dp"
                android:layout_height="17dp"
                android:scaleType="fitXY"
                android:contentDescription="@null"/>
    </LinearLayout>

    <!-- Rate Row -->
    <TextView
            android:id="@+id/text_rate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/layout_flags"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="4dp"
            android:text="0.92 EUR"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textColor="?android:attr/textColorPrimary"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"/>

    <TextView
            android:id="@+id/text_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:text="Updated: Jan 15"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="?android:attr/textColorTertiary"/>

</RelativeLayout>
